generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  type      String
  cost      Float?
  createdAt DateTime @default(now())

  usages ReportResource[]
}

model Report {
  id          String   @id @default(cuid())
  date        String
  description String?
  createdAt   DateTime @default(now())

  resources ReportResource[]
}

model ReportResource {
  id         String   @id @default(cuid())
  reportId   String
  resourceId String
  quantity   Float
  unitCost   Float
  totalCost  Float

  report     Report   @relation(fields: [reportId], references: [id])
  resource   Resource @relation(fields: [resourceId], references: [id])
}
model Resource {
  id        String   @id @default(cuid())
  name      String
  type      String
  cost      Float?
  stock     Float?   // 👈 NUOVO
  createdAt DateTime @default(now())

  usages ReportResource[]
}
