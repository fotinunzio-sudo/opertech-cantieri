generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Commessa {
  id          String   @id @default(cuid())
  name        String
  description String?
  budget      Float?
  createdAt   DateTime @default(now())

  reports     Report[]
  ledger      Ledger[]
  receipts    Receipt[]
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  type      String
  cost      Float?
  stock     Float?
  createdAt DateTime @default(now())

  usages    ReportResource[]
}

model Report {
  id          String   @id @default(cuid())
  date        String
  description String?
  createdAt   DateTime @default(now())

  commessaId  String?
  commessa    Commessa? @relation(fields: [commessaId], references: [id])

  resources   ReportResource[]
}

model ReportResource {
  id         String   @id @default(cuid())
  reportId   String
  resourceId String
  quantity   Float
  unitCost   Float
  totalCost  Float

  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([resourceId])
}

model Ledger {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  type        String
  description String
  amount      Float
  commessaId  String?
  commessa    Commessa? @relation(fields: [commessaId], references: [id])
  createdAt   DateTime @default(now())
}

model Receipt {
  id          String   @id @default(cuid())
  fileUrl     String
  fileName    String?
  amount      Float
  description String?
  date        DateTime @default(now())

  commessaId  String?
  commessa    Commessa? @relation(fields: [commessaId], references: [id])

  createdAt   DateTime @default(now())
}
