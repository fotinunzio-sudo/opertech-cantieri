generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  type      String
  cost      Float?
  createdAt DateTime @default(now())

  reports    Report[] @relation("ReportResources")
}

model Report {
  id          String     @id @default(cuid())
  date        String
  description String?
  createdAt   DateTime   @default(now())

  resources   Resource[] @relation("ReportResources")
}
